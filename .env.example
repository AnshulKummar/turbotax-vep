# Anthropic Claude API key — used by the recommendation engine and live co-pilot.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model ID for the recommendation engine. Default is claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# SQLite audit trail location. Defaults to ./data/audit.db (gitignored).
AUDIT_DB_PATH=./data/audit.db
